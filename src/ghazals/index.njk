      <span class="e-title">{{ g.title }}</span>
      <span class="e-poet">{{ g.poet }}</span>
      {% if g.raga %}<span class="e-raga">{{ g.raga }}</span>{% endif %}
    </a>
  {% endfor %}
</nav>
