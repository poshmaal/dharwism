<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} — dharwism{% else %}dharwism{% endif %}</title>
  <meta name="description" content="{{ description or 'Ragas, ghazals, and the words that go with them.' }}">
  {% if canonical %}<link rel="canonical" href="https://dharwism.com{{ canonical }}">{% endif %}

  <!-- Open Graph for nice link previews -->
  <meta property="og:type" content="{{ ogType or 'website' }}">
  <meta property="og:title" content="{{ title or 'dharwism' }}">
  <meta property="og:description" content="{{ description or 'Ragas, ghazals, and the words that go with them.' }}">
  <meta property="og:site_name" content="dharwism">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Spectral:ital,wght@0,400;0,500;1,400&family=Inter:wght@400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/styles.css">
</head>
<body>
  <header class="site-head">
    <div class="wrap">
      <nav class="site-nav">
        <a class="brand" href="/">dharwism<span class="dot">.</span></a>
        <span class="links">
          <a href="/ghazals/" {% if section == 'ghazals' %}aria-current="page"{% endif %}>Ghazals</a>
          <a href="/ragas/" {% if section == 'ragas' %}aria-current="page"{% endif %}>Ragas</a>
        </span>
      </nav>
    </div>
  </header>

  <main class="wrap">
    {{ content | safe }}
  </main>

  <footer class="site-foot">
    <span class="glyph">&#x266B;</span>
    <p>dharwism &middot; ragas &amp; ghazals</p>
  </footer>
</body>
</html>
